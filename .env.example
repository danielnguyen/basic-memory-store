# Docker Compose / container template.
# For local host-run, copy `api/.env.example` to `api/.env`.

# Where all persistent data lives (bind mounts)
_VOLUME_MEMORYGW=/srv/volumes/memory-gateway

# Secrets
POSTGRES_PASSWORD=change_me
MEMORY_API_KEY=change_me

# LiteLLM / Provider keys
OPENAI_API_KEY=sk-...
# Optional: if you later lock down LiteLLM with a key
LITELLM_API_KEY=

# Request id + traces/profiles
REQUIRE_REQUEST_ID=true
ENFORCE_REQUEST_ID_HEADER_BODY_MATCH=true
ENABLE_TRACE_STORAGE=true
TRACE_REDACT_PII=false
TRACE_MAX_PAYLOAD_BYTES=250000
ENABLE_PROFILE_RESOLVE=true
DEFAULT_PROFILE_NAME=dev
